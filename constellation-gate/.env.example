L9_ENVIRONMENT=local
GATE_LOCAL_NODE=gate

HOST=0.0.0.0
PORT=9000

L9_DEV_MODE=true
L9_REQUIRE_SIGNATURE=false

L9_SIGNING_KEY=
L9_SIGNING_KEY_ID=
L9_SIGNING_ALGORITHM=
# JSON object mapping key_id -> key_value for multi-key signature verification.
# Must be valid JSON. Example: {"key-1": "abc123", "key-2": "def456"}
L9_VERIFYING_KEYS_JSON={}

L9_ALLOWED_ACTIONS=
L9_ALLOWED_PACKET_TYPES=request,command,delegation,replay_request
L9_REQUIRE_IDEMPOTENCY_FOR_ACTIONS=

L9_ALLOWED_CLOCK_SKEW_SECONDS=30
L9_MAX_PACKET_BYTES=262144
L9_MAX_HOP_DEPTH=64
L9_MAX_DELEGATION_DEPTH=8
L9_MAX_ATTACHMENTS=32
L9_MAX_ATTACHMENT_SIZE_BYTES=10485760
L9_ATTACHMENT_ALLOWED_SCHEMES=
L9_ALLOW_PRIVATE_ATTACHMENT_HOSTS=false

L9_REPLAY_ENABLED=true
L9_VERIFY_HOP_SIGNATURES=false

# Canonical admin token env var (matches SDK GATE_ADMIN_TOKEN).
# L9_GATE_ADMIN_TOKEN is accepted as a backward-compatible alias.
GATE_ADMIN_TOKEN=

# Optional path to workflow definitions YAML file.
# If unset, workflow engine starts with no definitions (direct dispatch is used for all actions).
# If set, the file must exist and be valid YAML or startup will fail.
# GATE_WORKFLOW_CONFIG_PATH=engine/workflows.yaml
